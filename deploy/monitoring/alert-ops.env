# Alertmanager routing timings
ALERTMANAGER_ROUTE_GROUP_WAIT=30s
ALERTMANAGER_ROUTE_GROUP_INTERVAL=5m
ALERTMANAGER_ROUTE_REPEAT_INTERVAL=2h
ALERTMANAGER_ROUTE_WARNING_REPEAT_INTERVAL=2h
ALERTMANAGER_ROUTE_CRITICAL_REPEAT_INTERVAL=30m
ALERTMANAGER_ROUTE_CRITICAL_ESCALATION_REPEAT_INTERVAL=30m

# Gateway error ratios
ALERT_GATEWAY_WS_ERROR_RATIO_WARNING=0.01
ALERT_GATEWAY_WS_ERROR_RATIO_CRITICAL=0.03
ALERT_GATEWAY_WS_ERROR_MIN_RPS_WARNING=1
ALERT_GATEWAY_WS_ERROR_MIN_RPS_CRITICAL=1
ALERT_GATEWAY_WS_ERROR_FOR_WARNING=10m
ALERT_GATEWAY_WS_ERROR_FOR_CRITICAL=5m

ALERT_DOWNLINK_ERROR_RATIO_WARNING=0.005
ALERT_DOWNLINK_ERROR_RATIO_CRITICAL=0.02
ALERT_DOWNLINK_ERROR_MIN_RPS_WARNING=0.5
ALERT_DOWNLINK_ERROR_MIN_RPS_CRITICAL=0.5
ALERT_DOWNLINK_ERROR_FOR_WARNING=10m
ALERT_DOWNLINK_ERROR_FOR_CRITICAL=5m

# Command dispatch success ratio (gateway downlink)
ALERT_COMMAND_DISPATCH_SUCCESS_RATIO_WARNING=0.995
ALERT_COMMAND_DISPATCH_SUCCESS_RATIO_CRITICAL=0.980
ALERT_COMMAND_DISPATCH_MIN_RPS_WARNING=0.2
ALERT_COMMAND_DISPATCH_MIN_RPS_CRITICAL=0.5
ALERT_COMMAND_DISPATCH_FOR_WARNING=10m
ALERT_COMMAND_DISPATCH_FOR_CRITICAL=5m

# Command confirm timeout / execution failure ratios
ALERT_COMMAND_CONFIRM_TIMEOUT_RATIO_WARNING=0.05
ALERT_COMMAND_CONFIRM_TIMEOUT_RATIO_CRITICAL=0.15
ALERT_COMMAND_CONFIRM_TIMEOUT_MIN_RPS_WARNING=0.05
ALERT_COMMAND_CONFIRM_TIMEOUT_MIN_RPS_CRITICAL=0.10
ALERT_COMMAND_CONFIRM_TIMEOUT_FOR_WARNING=10m
ALERT_COMMAND_CONFIRM_TIMEOUT_FOR_CRITICAL=5m

ALERT_COMMAND_EXECUTION_FAILURE_RATIO_WARNING=0.03
ALERT_COMMAND_EXECUTION_FAILURE_RATIO_CRITICAL=0.10
ALERT_COMMAND_EXECUTION_FAILURE_MIN_RPS_WARNING=0.05
ALERT_COMMAND_EXECUTION_FAILURE_MIN_RPS_CRITICAL=0.10
ALERT_COMMAND_EXECUTION_FAILURE_FOR_WARNING=10m
ALERT_COMMAND_EXECUTION_FAILURE_FOR_CRITICAL=5m

# Command pipeline end-to-end latency (seconds)
ALERT_COMMAND_E2E_P95_SECONDS_WARNING=5.0
ALERT_COMMAND_E2E_P95_SECONDS_CRITICAL=8.0
ALERT_COMMAND_E2E_P95_FOR_WARNING=10m
ALERT_COMMAND_E2E_P95_FOR_CRITICAL=5m

# Pipeline error ratios
ALERT_PIPELINE_ERROR_RATIO_WARNING=0.01
ALERT_PIPELINE_ERROR_RATIO_CRITICAL=0.03
ALERT_PIPELINE_ERROR_MIN_RPS_WARNING=0.5
ALERT_PIPELINE_ERROR_MIN_RPS_CRITICAL=0.5
ALERT_PIPELINE_ERROR_FOR_WARNING=10m
ALERT_PIPELINE_ERROR_FOR_CRITICAL=5m

# Pipeline p95 latency (seconds)
ALERT_PIPELINE_P95_SECONDS_WARNING=1.5
ALERT_PIPELINE_P95_SECONDS_CRITICAL=3.0
ALERT_ASR_P95_FOR_WARNING=15m
ALERT_ASR_P95_FOR_CRITICAL=5m
ALERT_TRANSLATION_P95_FOR_WARNING=15m
ALERT_TRANSLATION_P95_FOR_CRITICAL=5m
ALERT_TTS_P95_FOR_WARNING=15m
ALERT_TTS_P95_FOR_CRITICAL=5m

# Kafka lag
ALERT_KAFKA_LAG_WARNING=1200
ALERT_KAFKA_LAG_CRITICAL=5000
ALERT_KAFKA_LAG_FOR_WARNING=10m
ALERT_KAFKA_LAG_FOR_CRITICAL=5m

# Control-plane fallback / auth
ALERT_ORCHESTRATOR_FALLBACK_RPS_WARNING=0.2
ALERT_ORCHESTRATOR_FALLBACK_RPS_CRITICAL=1.0
ALERT_ORCHESTRATOR_FALLBACK_FOR_WARNING=10m
ALERT_ORCHESTRATOR_FALLBACK_FOR_CRITICAL=5m

ALERT_CONTROL_AUTH_DENY_RATIO_WARNING=0.20
ALERT_CONTROL_AUTH_DENY_RATIO_CRITICAL=0.40
ALERT_CONTROL_AUTH_DENY_MIN_RPS_WARNING=0.05
ALERT_CONTROL_AUTH_DENY_MIN_RPS_CRITICAL=0.10
ALERT_CONTROL_AUTH_DENY_FOR_WARNING=10m
ALERT_CONTROL_AUTH_DENY_FOR_CRITICAL=5m

ALERT_CONTROL_EXTERNAL_UNAVAILABLE_RPS_WARNING=0.01
ALERT_CONTROL_EXTERNAL_UNAVAILABLE_RPS_CRITICAL=0.05
ALERT_CONTROL_EXTERNAL_UNAVAILABLE_FOR_WARNING=10m
ALERT_CONTROL_EXTERNAL_UNAVAILABLE_FOR_CRITICAL=10m

ALERT_CONTROL_HYBRID_FALLBACK_RPS_WARNING=0.05
ALERT_CONTROL_HYBRID_FALLBACK_RPS_CRITICAL=0.20
ALERT_CONTROL_HYBRID_FALLBACK_FOR_WARNING=10m
ALERT_CONTROL_HYBRID_FALLBACK_FOR_CRITICAL=5m
