{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kafka-asr.local/schemas/translation.result.v1.json",
  "title": "translation.result.v1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "traceId",
    "sessionId",
    "tenantId",
    "producer",
    "seq",
    "ts",
    "idempotencyKey",
    "payload"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "translation.result" },
    "eventVersion": { "const": "v1" },
    "traceId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "roomId": { "type": "string" },
    "userId": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "ts": { "type": "integer", "minimum": 0 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["sourceText", "translatedText", "sourceLang", "targetLang", "engine"],
      "properties": {
        "sourceText": { "type": "string" },
        "translatedText": { "type": "string" },
        "sourceLang": { "type": "string", "minLength": 2 },
        "targetLang": { "type": "string", "minLength": 2 },
        "engine": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
