{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kafka-asr.local/schemas/command.dispatch.v1.json",
  "title": "command.dispatch.v1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "traceId",
    "sessionId",
    "tenantId",
    "producer",
    "seq",
    "ts",
    "idempotencyKey",
    "payload"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "command.dispatch" },
    "eventVersion": { "const": "v1" },
    "traceId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "roomId": { "type": "string" },
    "userId": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "ts": { "type": "integer", "minimum": 0 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": [
        "executionId",
        "executionMode",
        "commandText",
        "confirmRequired",
        "confirmRound",
        "maxConfirmRounds"
      ],
      "properties": {
        "executionId": { "type": "string", "minLength": 1 },
        "executionMode": { "type": "string", "enum": ["CLIENT_BRIDGE"] },
        "commandText": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "subIntent": { "type": "string", "minLength": 1 },
        "confirmRequired": { "type": "boolean" },
        "confirmRound": { "type": "integer", "minimum": 1 },
        "maxConfirmRounds": { "type": "integer", "minimum": 1 },
        "confirmToken": { "type": "string", "minLength": 1 },
        "expiresInSec": { "type": "integer", "minimum": 1 },
        "traceId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
