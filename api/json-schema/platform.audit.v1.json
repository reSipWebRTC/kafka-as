{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kafka-asr.local/schemas/platform.audit.v1.json",
  "title": "platform.audit.v1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "traceId",
    "sessionId",
    "tenantId",
    "producer",
    "seq",
    "ts",
    "idempotencyKey",
    "payload"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "platform.audit" },
    "eventVersion": { "const": "v1" },
    "traceId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "userId": { "type": "string", "minLength": 1 },
    "roomId": { "type": "string" },
    "producer": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "ts": { "type": "integer", "minimum": 0 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["service", "action", "outcome", "resourceType", "resourceId"],
      "properties": {
        "service": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "outcome": {
          "type": "string",
          "enum": ["SUCCESS", "FAILED", "PARTIAL", "SKIPPED"]
        },
        "resourceType": { "type": "string", "minLength": 1 },
        "resourceId": { "type": "string", "minLength": 1 },
        "sourceTopic": { "type": "string", "minLength": 1 },
        "targetTopic": { "type": "string", "minLength": 1 },
        "failureType": { "type": "string", "minLength": 1 },
        "failureMessage": { "type": "string" },
        "reasonCode": { "type": "string", "minLength": 1 },
        "occurredAtMs": { "type": "integer", "minimum": 0 },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
