{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kafka-asr.local/schemas/session.control.v1.json",
  "title": "session.control.v1",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "traceId",
    "sessionId",
    "tenantId",
    "producer",
    "seq",
    "ts",
    "idempotencyKey",
    "payload"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "session.control" },
    "eventVersion": { "const": "v1" },
    "traceId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "roomId": { "type": "string" },
    "producer": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 0 },
    "ts": { "type": "integer", "minimum": 0 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["action", "status"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["START", "STOP", "PAUSE", "RESUME", "RECONNECT"]
        },
        "status": {
          "type": "string",
          "enum": [
            "INIT",
            "CONNECTING",
            "STREAMING",
            "ASR_ACTIVE",
            "TRANSLATING",
            "TTS_ACTIVE",
            "DRAINING",
            "CLOSED",
            "FAILED"
          ]
        },
        "sourceLang": { "type": "string" },
        "targetLang": { "type": "string" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
